    function getStateTriggers(stateId) {
      const s = machine.states[stateId]; if (!s) return [];
      const out = [];
      for (const row of (s.components || [])) {
        if (row.type === 'buttons')
          for (const b of (row.buttons || []))
            if (b.customId) out.push({ id: b.customId, label: b.label || 'Button' });
        if (row.type === 'select')
          for (const o of (row.select?.options || []))
            if (o.customId) out.push({ id: o.customId, label: o.label || 'Option' });
      }
      return out;
    }

    function renderTransitionsPanel() {
      const s = getSelectedState(); if (!s) return;
      if (!s.on) s.on = {};
      // Normalize action arrays to objects for backward compat
      for (const tr of Object.values(s.on)) {
        if (!tr.actions) tr.actions = [];
        tr.actions = tr.actions.map(a => typeof a === 'string' ? { type: a } : a);
      }
      const on          = s.on;
      const otherStates = Object.keys(machine.states).filter(id => id !== selectedStateId);
      // Include current state as a "(self)" self-loop option at the top of the list
      const selfLabel   = esc((machine.states[selectedStateId]?.label || selectedStateId) + ' (self)');
      const stateOpts   = '<option value="' + esc(selectedStateId) + '">' + selfLabel + '</option>'
        + otherStates.map(id =>
          '<option value="' + esc(id) + '">' + esc(machine.states[id].label || id) + '</option>').join('');
      const triggers  = getStateTriggers(selectedStateId);
      const usedIds   = Object.keys(on);
      const available = triggers.filter(t => !usedIds.includes(t.id));

      // Render param inputs for one pipeline step
      function stepParamHTML(tid, step, idx) {
        const def = ACTION_DEFS[step.type];
        if (!def || !def.params.length) return '';
        return '<div class="tr-step-params">' + def.params.map(p => {
          const val   = (step[p.key] !== undefined && step[p.key] !== null) ? step[p.key] : '';
          const attrD = ' data-tid="' + esc(tid) + '" data-idx="' + idx + '" data-key="' + esc(p.key) + '"';
          let inputHtml;
          if (p.type === 'role' || p.type === 'roles') {
            const isMulti  = p.type === 'roles';
            const selIds   = val ? String(val).split(',').map(v => v.trim()).filter(Boolean) : [];
            const optsHtml = guildRoles.map(r => {
              const act = selIds.includes(r.id) ? ' active' : '';
              return '<div class="tr-role-opt' + act + '" data-roleid="' + esc(r.id) + '">'
                + _ri(r)
                + '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + esc(r.name) + '</span>'
                + (act ? '<i data-lucide="check" style="width:10px;height:10px;flex-shrink:0;opacity:.8;"></i>' : '')
                + '</div>';
            }).join('');
            let pillInner;
            if (isMulti) {
              const tagsHtml = selIds.map(id => {
                const r = guildRoles.find(x => x.id === id);
                return '<span class="tr-role-tag" data-roleid="' + esc(id) + '">'
                  + _ri(r)
                  + esc(r ? r.name : id)
                  + '<span class="tr-role-tag-x" data-roleid="' + esc(id) + '">\xd7</span></span>';
              }).join('');
              pillInner = '<div class="tr-role-tags">' + (tagsHtml || '<span style="opacity:.4;font-size:.71rem;"><%= t.embeds.trSelectRoles %></span>') + '</div>'
                + '<i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:4px;flex-shrink:0;opacity:.4;"></i>';
            } else {
              const sr = guildRoles.find(r => r.id === String(val));
              pillInner = (sr
                ? _ri(sr) + '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">' + esc(sr.name) + '</span>'
                : '<i data-lucide="shield" style="width:12px;height:12px;opacity:.35;flex-shrink:0;"></i><span style="flex:1;opacity:.4;font-size:.71rem;"><%= t.embeds.trSelectRole %></span>')
                + '<i data-lucide="chevron-down" style="width:11px;height:11px;flex-shrink:0;opacity:.4;"></i>';
            }
            inputHtml =
              '<div class="tr-role-picker-wrap' + (isMulti ? ' multi' : '') + '" data-ptid="' + esc(tid) + '" data-pidx="' + idx + '" data-pkey="' + esc(p.key) + '">'
              + '<input type="hidden" class="tr-param-input"' + attrD + ' value="' + esc(String(val)) + '">'
              + '<div class="tr-role-pill">' + pillInner + '</div>'
              + '<div class="tr-role-drop">'
              + '<input class="tr-role-search" type="text" placeholder="<%= t.embeds.trSearchRoles %>">'
              + '<div class="tr-role-list">' + (guildRoles.length ? optsHtml : '<div style="padding:6px 8px;font-size:.72rem;opacity:.5;"><%= t.embeds.trNoRoles %></div>') + '</div>'
              + '</div>'
              + '</div>';
          } else if (p.type === 'textarea') {
            inputHtml = '<textarea class="form-input tr-param-input"'
              + ' placeholder="' + esc(p.placeholder || '') + '"'
              + attrD
              + ' style="min-height:70px;font-size:.72rem;width:100%;resize:vertical;">' + esc(String(val)) + '</textarea>';
          } else {
            inputHtml = '<input class="form-input tr-param-input" type="' + esc(p.type || 'text') + '"'
              + ' placeholder="' + esc(p.placeholder || '') + '"'
              + ' value="' + esc(String(val)) + '"'
              + attrD + '>';
          }
          return '<div class="tr-step-param">'
            + '<label>' + esc(p.label) + '</label>'
            + inputHtml
            + '</div>';
        }).join('') + '</div>';
      }

      // Render one pipeline step card
      function stepHTML(tid, step, idx) {
        const curDef  = ACTION_DEFS[step.type] || { label: step.type, params: [] };
        const curIcon = ACTION_ICONS[step.type] || 'zap';
        const curLbl  = _stripEmoji(curDef.label);
        const optItems = Object.entries(ACTION_DEFS).map(([k, v]) =>
          '<div class="tr-type-opt' + (step.type === k ? ' active' : '') + '" data-value="' + esc(k) + '">'
          + '<i data-lucide="' + esc(ACTION_ICONS[k] || 'zap') + '" style="width:13px;height:13px;flex-shrink:0;"></i>'
          + '<span>' + esc(_stripEmoji(v.label)) + '</span>'
          + '</div>'
        ).join('');
        return '<div class="tr-step" data-idx="' + idx + '">'
          + '<div class="tr-step-hd">'
          + '<div class="tr-type-picker" data-tid="' + esc(tid) + '" data-idx="' + idx + '">'
          + '<div class="tr-type-selected">'
          + '<i data-lucide="' + esc(curIcon) + '" style="width:13px;height:13px;flex-shrink:0;"></i>'
          + '<span class="tr-type-lbl">' + esc(curLbl) + '</span>'
          + '<i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:auto;flex-shrink:0;opacity:.5;"></i>'
          + '</div>'
          + '<div class="tr-type-menu">' + optItems + '</div>'
          + '</div>'
          + '<button class="state-act-btn del tr-step-del" data-tid="' + esc(tid) + '" data-idx="' + idx + '" title="Remove step">'
          + '<i data-lucide="x" style="width:10px;height:10px;"></i></button>'
          + '</div>'
          + stepParamHTML(tid, step, idx)
          + '</div>';
      }

      let html = '';
      if (!usedIds.length)
        html += '<p style="font-size:.78rem;color:var(--muted);margin-bottom:10px;"><%= t.embeds.jsNoTransitions %></p>';

      html += usedIds.map(tid => {
        const tr         = on[tid];
        const steps      = tr.actions || [];
        const pipeHtml   = steps.map((step, idx) => stepHTML(tid, step, idx)).join('');
        return '<div class="tr-item" data-tid="' + esc(tid) + '">'
          + '<div class="tr-item-hd">'
          + '<span class="tr-badge" title="' + esc(tid) + '">' + esc(tid.length > 18 ? tid.slice(0, 16) + '\u2026' : tid) + '</span>'
          + '<svg style="width:14px;height:14px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="rgba(203,194,255,.5)" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'
          + '<select class="form-select tr-target-sel" data-tid="' + esc(tid) + '" style="flex:1;">'
          + '<option value="">\u2014 <%= t.embeds.trTargetState %> \u2014</option>' + stateOpts + '</select>'
          + '<button class="state-act-btn del tr-remove-btn" data-tid="' + esc(tid) + '" title="Remove transition">'
          + '<i data-lucide="x" style="width:11px;height:11px;"></i></button>'
          + '</div>'
          + '<div class="tr-pipeline">'
          + pipeHtml
          + '<button class="btn btn-xs tr-step-add" data-tid="' + esc(tid) + '" style="margin-top:6px;font-size:.71rem;background:rgba(124,58,237,.08);border:1px dashed rgba(124,58,237,.25);color:var(--purple-l);border-radius:7px;padding:4px 10px;width:100%;justify-content:center;">'
          + '<i data-lucide="plus" style="width:11px;height:11px;"></i> <%= t.embeds.trAddStep %></button>'
          + '</div>'
          + '</div>';
      }).join('');

      if (available.length) {
        html += '<div style="display:flex;gap:7px;align-items:center;margin-top:10px;padding:10px;background:rgba(124,58,237,.04);border:1px dashed rgba(124,58,237,.2);border-radius:9px;">'
          + '<select class="form-select" id="trNewTrigger" style="flex:1;">'
          + '<option value="">\u2014 <%= t.embeds.trPickTrigger %> \u2014</option>'
          + available.map(t => '<option value="' + esc(t.id) + '">' + esc(t.label) + '</option>').join('')
          + '</select>'
          + '<button class="btn btn-primary btn-xs" id="trAddBtn">'
          + '<i data-lucide="plus" style="width:12px;height:12px;"></i> <%= t.embeds.trAdd %></button>'
          + '</div>';
      } else if (!triggers.length) {
        html += '<div style="margin-top:10px;padding:10px;background:rgba(255,255,255,.03);border-radius:9px;font-size:.76rem;color:var(--muted);">'
          + '<%= t.embeds.jsAddButtonsFirst %></div>';
      } else {
        html += '<p style="font-size:.74rem;color:var(--muted);margin-top:8px;">'
          + '<%= t.embeds.jsAllTriggersHaveTransitions %></p>';
      }

      $panelTransitions.innerHTML = html;
      lucide.createIcons();

      // Set selected targets
      usedIds.forEach(tid => {
        const sel = $panelTransitions.querySelector('.tr-target-sel[data-tid="' + tid + '"]');
        if (sel && on[tid].target) sel.value = on[tid].target;
      });

      // Target state change
      $panelTransitions.querySelectorAll('.tr-target-sel').forEach(sel => sel.addEventListener('change', () => {
        const ss = getSelectedState(); if (!ss?.on) return;
        if (!ss.on[sel.dataset.tid]) ss.on[sel.dataset.tid] = { target: '', actions: [] };
        ss.on[sel.dataset.tid].target = sel.value;
        updateArrows(); renderCanvas();
      }));

      // Custom type picker — toggle open on header click
      $panelTransitions.querySelectorAll('.tr-type-selected').forEach(btn => btn.addEventListener('click', e => {
        e.stopPropagation();
        const picker = btn.closest('.tr-type-picker');
        const isOpen = picker.classList.contains('open');
        $panelTransitions.querySelectorAll('.tr-type-picker.open').forEach(p => p.classList.remove('open'));
        if (!isOpen) { picker.classList.add('open'); lucide.createIcons(); }
      }));
      // Custom type picker — option click → reset action type and re-render
      $panelTransitions.querySelectorAll('.tr-type-opt').forEach(opt => opt.addEventListener('click', e => {
        e.stopPropagation();
        const picker = opt.closest('.tr-type-picker');
        const { tid, idx } = picker.dataset;
        const ss = getSelectedState(); if (!ss?.on) return;
        const acts = ss.on[tid]?.actions;
        if (!acts?.[+idx]) return;
        acts[+idx] = { type: opt.dataset.value };
        renderTransitionsPanel();
      }));

      // Param input change
      $panelTransitions.querySelectorAll('.tr-param-input').forEach(inp => inp.addEventListener('input', () => {
        const ss = getSelectedState(); if (!ss?.on) return;
        const { tid, idx, key } = inp.dataset;
        if (!tid || idx === undefined || !key) return;
        const acts = ss.on[tid]?.actions;
        if (!acts?.[+idx]) return;
        acts[+idx][key] = inp.type === 'number' ? (parseInt(inp.value) || 0) : inp.value;
      }));

      // Role picker — open / close
      $panelTransitions.querySelectorAll('.tr-role-pill').forEach(pill => pill.addEventListener('click', e => {
        e.stopPropagation();
        const wrap   = pill.closest('.tr-role-picker-wrap');
        const isOpen = wrap.classList.contains('open');
        $panelTransitions.querySelectorAll('.tr-role-picker-wrap.open').forEach(w => w.classList.remove('open'));
        if (!isOpen) {
          wrap.classList.add('open'); lucide.createIcons();
          const s = wrap.querySelector('.tr-role-search');
          if (s) { s.value = ''; s.focus(); wrap.querySelectorAll('.tr-role-opt').forEach(o => o.style.display = ''); }
        }
      }));
      // Role picker — search filter
      $panelTransitions.querySelectorAll('.tr-role-search').forEach(inp => {
        inp.addEventListener('click',   e => e.stopPropagation());
        inp.addEventListener('keydown', e => e.stopPropagation());
        inp.addEventListener('input',   e => {
          e.stopPropagation();
          const q = inp.value.toLowerCase();
          inp.closest('.tr-role-drop').querySelectorAll('.tr-role-opt').forEach(opt => {
            const name = opt.querySelector('span')?.textContent || '';
            opt.style.display = name.toLowerCase().includes(q) ? '' : 'none';
          });
        });
      });
      // Role picker — option click (single: close; multi: stay open & toggle)
      $panelTransitions.querySelectorAll('.tr-role-opt').forEach(opt => opt.addEventListener('click', e => {
        e.stopPropagation();
        const wrap    = opt.closest('.tr-role-picker-wrap');
        const isMulti = wrap.classList.contains('multi');
        const hidden  = wrap.querySelector('.tr-param-input');
        const rid     = opt.dataset.roleid;
        if (isMulti) {
          const cur = hidden.value ? hidden.value.split(',').map(v => v.trim()).filter(Boolean) : [];
          const i   = cur.indexOf(rid);
          if (i === -1) cur.push(rid); else cur.splice(i, 1);
          hidden.value = cur.join(',');
          _rolePickerReopen = { ptid: wrap.dataset.ptid, pidx: wrap.dataset.pidx, pkey: wrap.dataset.pkey };
        } else {
          hidden.value = rid;
        }
        hidden.dispatchEvent(new Event('input'));
        renderTransitionsPanel();
      }));
      // Multi-role — remove tag via × button
      $panelTransitions.querySelectorAll('.tr-role-tag-x').forEach(x => x.addEventListener('click', e => {
        e.stopPropagation();
        const wrap   = x.closest('.tr-role-picker-wrap');
        const hidden = wrap.querySelector('.tr-param-input');
        const rid    = x.dataset.roleid;
        const cur    = hidden.value ? hidden.value.split(',').map(v => v.trim()).filter(Boolean) : [];
        const i      = cur.indexOf(rid);
        if (i !== -1) cur.splice(i, 1);
        hidden.value = cur.join(',');
        hidden.dispatchEvent(new Event('input'));
        renderTransitionsPanel();
      }));
      // Re-open multi-role picker after re-render (keeps dropdown open while selecting multiple roles)
      if (_rolePickerReopen) {
        const rr = _rolePickerReopen; _rolePickerReopen = null;
        const rp = [...$panelTransitions.querySelectorAll('.tr-role-picker-wrap')]
          .find(w => w.dataset.ptid === rr.ptid && w.dataset.pidx === rr.pidx && w.dataset.pkey === rr.pkey);
        if (rp) { rp.classList.add('open'); lucide.createIcons(); const s = rp.querySelector('.tr-role-search'); if (s) s.focus(); }
      }

      // Remove step
      $panelTransitions.querySelectorAll('.tr-step-del').forEach(btn => btn.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss?.on) return;
        const acts = ss.on[btn.dataset.tid]?.actions; if (!acts) return;
        acts.splice(+btn.dataset.idx, 1);
        renderTransitionsPanel();
      }));

      // Add step
      $panelTransitions.querySelectorAll('.tr-step-add').forEach(btn => btn.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss?.on) return;
        if (!ss.on[btn.dataset.tid]) return;
        if (!ss.on[btn.dataset.tid].actions) ss.on[btn.dataset.tid].actions = [];
        ss.on[btn.dataset.tid].actions.push({ type: 'update_content' });
        renderTransitionsPanel();
      }));

      // Remove transition
      $panelTransitions.querySelectorAll('.tr-remove-btn').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss?.on) return;
        delete ss.on[b.dataset.tid];
        renderTransitionsPanel(); updateArrows(); renderCanvas();
      }));

      // Add new transition
      const addBtn = document.getElementById('trAddBtn');
      if (addBtn) addBtn.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.on) ss.on = {};
        const trigSel = document.getElementById('trNewTrigger');
        if (!trigSel?.value) return toast('Select a trigger component first', 'error');
        ss.on[trigSel.value] = { target: otherStates[0] || selectedStateId, actions: [{ type: 'update_content' }] };
        renderTransitionsPanel(); updateArrows(); renderCanvas();
      });
    }

    /* ────────────────── Permissions Panel ────────────────── */
    function renderPermissionsPanel() {
      const s = getSelectedState(); if (!s) return;
      if (!s.permissions) s.permissions = { allowedRoles: [], cooldown: 0, denyMessage: '' };
      const perms = s.permissions;
      const activeCnt = (perms.allowedRoles || []).length;

      const rolesHtml = guildRoles.length
        ? guildRoles.map(r => {
            const checked = (perms.allowedRoles || []).includes(r.id) ? ' checked' : '';
            const col = (!r.color || r.color === '#000000') ? '#99aab5' : r.color;
            return '<label class="perm-role-pill">'
              + '<input type="checkbox" class="perm-role-cb" data-rid="' + esc(r.id) + '"' + checked + '>'
              + '<span class="perm-role-dot" style="background:' + esc(col) + ';"></span>'
              + esc(r.name) + '</label>';
          }).join('')
        : '<p class="perm-no-roles"><%= t.embeds.jsNoRoles %></p>';

      $panelPermissions.innerHTML =
        '<div class="perm-section">'
        + '<div class="perm-section-hd"><i data-lucide="shield" style="width:13px;height:13px;"></i>&nbsp;'
        + '<%= t.embeds.jsAllowedRoles %></div>'
        + '<p class="perm-desc">'
        + '<%= t.embeds.jsPermDesc %>'
        + '</p>'
        + '<div class="perm-roles-grid">' + rolesHtml + '</div>'
        + (activeCnt
           ? '<div class="perm-active-badge"><i data-lucide="lock" style="width:10px;height:10px;"></i>&nbsp;'
             + activeCnt + ' role' + (activeCnt > 1 ? 's' : '') + ' required</div>'
           : '')
        + '</div>'

        + '<div class="perm-section">'
        + '<div class="perm-section-hd"><i data-lucide="timer" style="width:13px;height:13px;"></i>&nbsp;Cooldown</div>'
        + '<p class="perm-desc"><%= t.embeds.jsCooldownDesc %></p>'
        + '<div style="display:flex;align-items:center;gap:8px;">'
        + '<input type="number" class="form-input" id="permCooldown" min="0" max="86400" value="'
        + (perms.cooldown || 0) + '" style="width:88px;">'
        + '<span style="font-size:.76rem;color:var(--muted);"><%= t.embeds.jsSeconds %></span>'
        + '</div>'
        + '</div>'

        + '<div class="perm-section">'
        + '<div class="perm-section-hd"><i data-lucide="message-square-x" style="width:13px;height:13px;"></i>&nbsp;'
        + '<%= t.embeds.jsDenyMessage %></div>'
        + '<input class="form-input" id="permDenyMsg" value="' + esc(perms.denyMessage || '')
        + '" placeholder="<%= t.embeds.jsDenyPlaceholder %>">'
        + '<p style="font-size:.71rem;color:var(--muted);margin-top:4px;"><%= t.embeds.jsDenyMessageDesc %></p>'
        + '</div>';

      lucide.createIcons();

      $panelPermissions.querySelectorAll('.perm-role-cb').forEach(cb => {
        cb.addEventListener('change', () => {
          const ss = getSelectedState(); if (!ss) return;
          if (!ss.permissions) ss.permissions = { allowedRoles: [], cooldown: 0, denyMessage: '' };
          const rid = cb.dataset.rid;
          if (cb.checked) {
            if (!ss.permissions.allowedRoles.includes(rid)) ss.permissions.allowedRoles.push(rid);
          } else {
            ss.permissions.allowedRoles = ss.permissions.allowedRoles.filter(r => r !== rid);
          }
          renderPermissionsPanel();
        });
      });

      document.getElementById('permCooldown').addEventListener('change', function() {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.permissions) ss.permissions = { allowedRoles: [], cooldown: 0, denyMessage: '' };
        ss.permissions.cooldown = Math.max(0, parseInt(this.value) || 0);
      });

      document.getElementById('permDenyMsg').addEventListener('input', function() {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.permissions) ss.permissions = { allowedRoles: [], cooldown: 0, denyMessage: '' };
        ss.permissions.denyMessage = this.value;
      });
    }

    /* ────────────────── Smart Triggers Panel ────────────────── */
    function updateTriggersCountBadge() {
      const n = (machine.triggers || []).length;
      const b = document.getElementById('trgCountBadge');
      if (b) { b.textContent = n; b.style.display = n ? '' : 'none'; }
    }

    function renderTriggersModal() {
      const triggers = machine.triggers || [];
      const channelOptHtml = '<option value="">\u2014 <%= t.embeds.trgAllChannels %> \u2014</option>'
        + guildChannels.map(c => '<option value="' + esc(c.id) + '">#' + esc(c.name) + '</option>').join('');
      const stateOptHtml = '<option value="">\u2014 <%= t.embeds.trgInitialState %> \u2014</option>'
        + Object.keys(machine.states).map(id =>
            '<option value="' + esc(id) + '">' + esc(machine.states[id]?.label || id) + '</option>').join('');
      const actOptHtml = Object.entries(TRIGGER_ACTION_DEFS)
        .map(([k, v]) => '<option value="' + esc(k) + '">' + esc(v.label) + '</option>').join('');
      const typeOptHtml = Object.entries(TRIGGER_TYPE_DEFS)
        .map(([k, v]) => '<option value="' + esc(k) + '">' + esc(v.label) + '</option>').join('');
      const $body = document.getElementById('triggersModalBody');
      if (!triggers.length) {
        $body.innerHTML = '<div style="text-align:center;padding:28px 16px;color:var(--muted);font-size:.82rem;">'
          + '<svg xmlns="http://www.w3.org/2000/svg" style="display:block;margin:0 auto 12px;width:30px;height:30px;opacity:.3;stroke:currentColor;fill:none;stroke-width:2;" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'
          + 'No smart triggers yet. Click <strong><%= t.embeds.trAdd %></strong> to start automating.</div>';
        return;
      }
      $body.innerHTML = '<div class="trg-list">' + triggers.map((tr, i) => {
        const def = TRIGGER_TYPE_DEFS[tr.type] || TRIGGER_TYPE_DEFS.cron;
        const paramsHtml = def.params.map(p => {
          const val = tr[p.key] !== undefined ? tr[p.key] : '';
          let inp = '';
          if (p.type === 'checkbox') {
            inp = '<label style="display:flex;align-items:center;gap:5px;cursor:pointer;padding-top:2px;">'
              + '<input type="checkbox" class="trg-cb-inp" data-ti="' + i + '" data-key="' + esc(p.key) + '"'
              + (val ? ' checked' : '') + ' style="width:13px;height:13px;accent-color:var(--purple);cursor:pointer;">'
              + '<span style="font-size:.72rem;color:var(--white);">' + esc(p.label) + '</span></label>';
          } else if (p.type === 'channel') {
            inp = '<select class="form-select trg-ch-inp" data-ti="' + i + '" data-key="' + esc(p.key) + '" style="font-size:.72rem;">'
              + channelOptHtml + '</select>';
          } else if (p.type === 'role' || p.type === 'roles') {
            const isMulti  = p.type === 'roles';
            const selIds   = val ? String(val).split(',').map(v => v.trim()).filter(Boolean) : [];
            const optsHtml = guildRoles.map(r => {
              const act = selIds.includes(r.id) ? ' active' : '';
              return '<div class="tr-role-opt' + act + '" data-roleid="' + esc(r.id) + '">'
                + _ri(r)
                + '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + esc(r.name) + '</span>'
                + (act ? '<i data-lucide="check" style="width:10px;height:10px;flex-shrink:0;opacity:.8;"></i>' : '')
                + '</div>';
            }).join('');
            let pillInner;
            if (isMulti) {
              const tagsHtml = selIds.map(id => {
                const r = guildRoles.find(x => x.id === id);
                return '<span class="tr-role-tag" data-roleid="' + esc(id) + '">'
                  + _ri(r)
                  + esc(r ? r.name : id)
                  + '<span class="tr-role-tag-x" data-roleid="' + esc(id) + '">\xd7</span></span>';
              }).join('');
              pillInner = '<div class="tr-role-tags">' + (tagsHtml || '<span style="opacity:.4;font-size:.71rem;"><%= t.embeds.trSelectRoles %></span>') + '</div>'
                + '<i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:4px;flex-shrink:0;opacity:.4;"></i>';
            } else {
              const sr = guildRoles.find(r => r.id === String(val));
              pillInner = (sr
                ? _ri(sr) + '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">' + esc(sr.name) + '</span>'
                : '<i data-lucide="shield" style="width:12px;height:12px;opacity:.35;flex-shrink:0;"></i><span style="flex:1;opacity:.4;font-size:.71rem;"><%= t.embeds.trSelectRole %></span>')
                + '<i data-lucide="chevron-down" style="width:11px;height:11px;flex-shrink:0;opacity:.4;"></i>';
            }
            inp = '<div class="tr-role-picker-wrap trg-role-wrap' + (isMulti ? ' multi' : '') + '" data-pti="' + i + '" data-pkey="' + esc(p.key) + '">'
              + '<input type="hidden" class="trg-role-inp" data-ti="' + i + '" data-key="' + esc(p.key) + '" value="' + esc(String(val)) + '">'
              + '<div class="tr-role-pill">' + pillInner + '</div>'
              + '<div class="tr-role-drop">'
              + '<input class="tr-role-search" type="text" placeholder="<%= t.embeds.trSearchRoles %>">'
              + '<div class="tr-role-list">' + (guildRoles.length ? optsHtml : '<div style="padding:6px 8px;font-size:.72rem;opacity:.5;"><%= t.embeds.trNoRoles %></div>') + '</div>'
              + '</div>'
              + '</div>';
          } else {
            inp = '<input class="form-input trg-txt-inp" data-ti="' + i + '" data-key="' + esc(p.key) + '"'
              + ' type="text" value="' + esc(String(val)) + '" placeholder="' + esc(p.placeholder || '') + '"'
              + ' style="font-size:.72rem;">';
          }
          return '<div class="trg-param-field">'
            + (p.type !== 'checkbox' ? '<span class="trg-param-label">' + esc(p.label) + '</span>' : '')
            + inp + '</div>';
        }).join('');
        return '<div class="trg-item">'
          + '<div class="trg-item-hd">'
          + '<label class="trg-toggle"><input type="checkbox" class="trg-enabled-inp" data-ti="' + i + '"'
          + (tr.enabled !== false ? ' checked' : '') + '><span class="trg-toggle-slider"></span></label>'
          + '<select class="form-select trg-type-inp" data-ti="' + i + '" style="flex:1;font-size:.72rem;">'
          + typeOptHtml + '</select>'
          + '<button class="state-act-btn del trg-del-btn" data-ti="' + i + '" style="flex-shrink:0;" title="Delete">'
          + '<i data-lucide="trash-2" style="width:11px;height:11px;"></i></button>'
          + '</div>'
          + (def.params.length ? '<div class="trg-params">' + paramsHtml + '</div>' : '')
          + '<div class="trg-params">'
          + '<div class="trg-param-field"><span class="trg-param-label"><%= t.embeds.trgTargetState %></span>'
          + '<select class="form-select trg-state-inp" data-ti="' + i + '" style="font-size:.72rem;">'
          + stateOptHtml + '</select></div>'
          + '<div class="trg-param-field"><span class="trg-param-label"><%= t.embeds.trgAction %></span>'
          + '<select class="form-select trg-act-inp" data-ti="' + i + '" style="font-size:.72rem;">'
          + actOptHtml + '</select></div>'
          + '</div></div>';
      }).join('') + '</div>';
      lucide.createIcons();
      // Post-render: set select values (can't pre-select via innerHTML)
      triggers.forEach((tr, i) => {
        const tyS = document.querySelector('.trg-type-inp[data-ti="' + i + '"]');  if (tyS) tyS.value = tr.type || 'cron';
        const stS = document.querySelector('.trg-state-inp[data-ti="' + i + '"]'); if (stS && tr.targetState) stS.value = tr.targetState;
        const acS = document.querySelector('.trg-act-inp[data-ti="' + i + '"]');
        if (acS) {
          const av = (tr.actions || []).map(a => typeof a === 'string' ? a : a?.type).filter(Boolean)[0] || 'send_to_channel';
          acS.value = av;
        }
        document.querySelectorAll('.trg-ch-inp[data-ti="' + i + '"]').forEach(s => { if (tr[s.dataset.key]) s.value = tr[s.dataset.key]; });
      });
      // Events
      document.querySelectorAll('.trg-enabled-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti].enabled = el.checked; }));
      document.querySelectorAll('.trg-type-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti].type = el.value; renderTriggersModal(); }));
      document.querySelectorAll('.trg-txt-inp').forEach(el => el.addEventListener('input', () => { machine.triggers[+el.dataset.ti][el.dataset.key] = el.value; }));
      document.querySelectorAll('.trg-ch-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti][el.dataset.key] = el.value; }));
      document.querySelectorAll('.trg-cb-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti][el.dataset.key] = el.checked; }));
      // Role picker events (triggers modal)
      document.querySelectorAll('.trg-role-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti][el.dataset.key] = el.value; }));
      $body.querySelectorAll('.trg-role-wrap .tr-role-pill').forEach(pill => pill.addEventListener('click', e => {
        e.stopPropagation();
        const wrap   = pill.closest('.trg-role-wrap');
        const isOpen = wrap.classList.contains('open');
        $body.querySelectorAll('.trg-role-wrap.open').forEach(w => w.classList.remove('open'));
        if (!isOpen) {
          wrap.classList.add('open'); lucide.createIcons();
          const s = wrap.querySelector('.tr-role-search');
          if (s) { s.value = ''; s.focus(); wrap.querySelectorAll('.tr-role-opt').forEach(o => o.style.display = ''); }
        }
      }));
      $body.querySelectorAll('.trg-role-wrap .tr-role-search').forEach(inp => {
        inp.addEventListener('click',   e => e.stopPropagation());
        inp.addEventListener('keydown', e => e.stopPropagation());
        inp.addEventListener('input',   e => {
          e.stopPropagation();
          const q = inp.value.toLowerCase();
          inp.closest('.tr-role-drop').querySelectorAll('.tr-role-opt').forEach(opt => {
            const name = opt.querySelector('span')?.textContent || '';
            opt.style.display = name.toLowerCase().includes(q) ? '' : 'none';
          });
        });
      });
      $body.querySelectorAll('.trg-role-wrap .tr-role-opt').forEach(opt => opt.addEventListener('click', e => {
        e.stopPropagation();
        const wrap    = opt.closest('.trg-role-wrap');
        const isMulti = wrap.classList.contains('multi');
        const hidden  = wrap.querySelector('.trg-role-inp');
        const rid     = opt.dataset.roleid;
        if (isMulti) {
          const cur = hidden.value ? hidden.value.split(',').map(v => v.trim()).filter(Boolean) : [];
          const ii  = cur.indexOf(rid);
          if (ii === -1) cur.push(rid); else cur.splice(ii, 1);
          hidden.value = cur.join(',');
          _trgRolePickerReopen = { pti: wrap.dataset.pti, pkey: wrap.dataset.pkey };
        } else {
          hidden.value = rid;
        }
        hidden.dispatchEvent(new Event('change'));
        renderTriggersModal();
      }));
      $body.querySelectorAll('.trg-role-wrap .tr-role-tag-x').forEach(x => x.addEventListener('click', e => {
        e.stopPropagation();
        const wrap   = x.closest('.trg-role-wrap');
        const hidden = wrap.querySelector('.trg-role-inp');
        const rid    = x.dataset.roleid;
        const cur    = hidden.value ? hidden.value.split(',').map(v => v.trim()).filter(Boolean) : [];
        const ii     = cur.indexOf(rid);
        if (ii !== -1) cur.splice(ii, 1);
        hidden.value = cur.join(',');
        hidden.dispatchEvent(new Event('change'));
        renderTriggersModal();
      }));
      if (_trgRolePickerReopen) {
        const rr = _trgRolePickerReopen; _trgRolePickerReopen = null;
        const rp = [...$body.querySelectorAll('.trg-role-wrap')]
          .find(w => w.dataset.pti === rr.pti && w.dataset.pkey === rr.pkey);
        if (rp) { rp.classList.add('open'); lucide.createIcons(); const s = rp.querySelector('.tr-role-search'); if (s) s.focus(); }
      }
      document.querySelectorAll('.trg-state-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti].targetState = el.value; }));
      document.querySelectorAll('.trg-act-inp').forEach(el => el.addEventListener('change', () => { machine.triggers[+el.dataset.ti].actions = [el.value]; }));
      document.querySelectorAll('.trg-del-btn').forEach(btn => btn.addEventListener('click', () => {
        machine.triggers.splice(+btn.dataset.ti, 1);
        renderTriggersModal();
        updateTriggersCountBadge();
      }));
    }

    /* ────────────────── Preview ────────────────── */
    const _botInfo = (() => { try { return JSON.parse(document.getElementById('_data_botInfo').textContent); } catch (e) { return {}; } })();
    function renderPreview() {
      const s          = getSelectedState();
      const embeds     = s?.embeds     || [];
      const components = s?.components || [];
      // Bot avatar / name
      if (_botInfo.avatar)
        $prevAvatar.innerHTML = '<img src="' + _botInfo.avatar + '" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" onerror="this.parentElement.textContent=\'' + esc((_botInfo.username||'B')[0]) + '\'">';
      else
        $prevAvatar.textContent = (_botInfo.username || 'Bot')[0].toUpperCase();
      $prevAuthor.innerHTML = '<span style="font-weight:700;color:#f2f3f5;">' + esc(_botInfo.username || 'Bot') + '</span> <span class="bot-tag">BOT</span>';
      // Embeds
      $prevEmbeds.innerHTML = embeds.map(emb => {
        const col = emb.color || '#5865f2';
        let h = '<div class="preview-embed" style="border-left-color:' + esc(col) + ';">';
        if (emb.author?.name) {
          h += '<div class="preview-embed-author">';
          if (emb.author.iconUrl) h += '<img src="' + esc(emb.author.iconUrl) + '" onerror="this.style.display=\'none\'">';
          h += esc(emb.author.name) + '</div>';
        }
        if (emb.thumbnail) h += '<img class="preview-embed-thumb" src="' + esc(emb.thumbnail) + '" onerror="this.style.display=\'none\'">';
        if (emb.title)     h += '<div class="preview-embed-title">' + (emb.url ? '<a href="'+esc(emb.url)+'" style="color:#00a8fc;text-decoration:none;">'+esc(emb.title)+'</a>' : esc(emb.title)) + '</div>';
        if (emb.description) h += '<div class="preview-embed-desc">' + esc(emb.description) + '</div>';
        if (emb.fields?.length) {
          h += '<div class="preview-embed-fields">';
          emb.fields.forEach(f => {
            h += '<div class="preview-embed-field ' + (f.inline ? 'inline' : 'full') + '">'
              + '<div class="preview-embed-field-name">'  + esc(f.name  || '\u200b') + '</div>'
              + '<div class="preview-embed-field-value">' + esc(f.value || '\u200b') + '</div></div>';
          });
          h += '</div>';
        }
        if (emb.image) h += '<img class="preview-embed-img" src="' + esc(emb.image) + '" onerror="this.style.display=\'none\'">';
        if (emb.footer?.text || emb.timestamp) {
          h += '<div class="preview-embed-footer">';
          if (emb.footer?.iconUrl) h += '<img src="' + esc(emb.footer.iconUrl) + '" onerror="this.style.display=\'none\'">';
          const parts = [];
          if (emb.footer?.text) parts.push(esc(emb.footer.text));
          if (emb.timestamp)    parts.push(new Date().toLocaleDateString());
          h += parts.join(' \u2022 ') + '</div>';
        }
        h += '</div>';
        return h;
      }).join('');
      // Components
      $prevComps.innerHTML = components.map(row => {
        if (row.type === 'buttons')
          return '<div class="preview-action-row">' + (row.buttons||[]).map(b => {
            const cls = { Primary:'st-primary', Secondary:'st-secondary', Success:'st-success', Danger:'st-danger', Link:'st-link' }[b.style] || 'st-primary';
            return '<button class="preview-btn ' + cls + '">' + (b.emoji ? esc(b.emoji) + ' ' : '') + esc(b.label || 'Button') + '</button>';
          }).join('') + '</div>';
        if (row.type === 'select') {
          const sel = row.select || {};
          return '<select class="preview-select"><option>' + esc(sel.placeholder || 'Select an option\u2026') + '</option>'
            + (sel.options||[]).map(o => '<option>' + (o.emoji ? esc(o.emoji)+' ' : '') + esc(o.label||'Option') + '</option>').join('')
            + '</select>';
        }
        return '';
      }).join('');
    }

