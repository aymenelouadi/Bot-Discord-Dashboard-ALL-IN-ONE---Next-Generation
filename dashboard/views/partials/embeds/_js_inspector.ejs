    function renderInspector() {
      // Hide group inspector whenever a state is being inspected
      const $ig = document.getElementById('inspGroupContent');
      const $ms = document.getElementById('multiSelPanel');
      if ($ig) $ig.style.display = 'none';
      selectedGroupId = null;
      // Multi-selection panel
      if (_multiSel.size > 1) {
        $inspEmpty.style.display   = 'none';
        $inspContent.style.display = 'none';
        if ($ms) {
          $ms.style.display = 'flex';
          const lbl = document.getElementById('multiSelLbl');
          if (lbl) lbl.textContent = _multiSel.size + ' <%= t.embeds.jsMultiSelSelected %>';
        }
        return;
      }
      if ($ms) $ms.style.display = 'none';
      const s = getSelectedState();
      if (!s) { $inspEmpty.style.display = ''; $inspContent.style.display = 'none'; return; }
      $inspEmpty.style.display    = 'none';
      $inspContent.style.display  = 'flex';
      $inspLabel.value  = s.label || '';
      $inspColor.value  = s.color || '#7c3aed';
      // Sync active color swatch
      document.querySelectorAll('.color-swatch').forEach(sw => {
        sw.classList.toggle('active', sw.dataset.color === (s.color || '#7c3aed'));
      });
      const isInit = machine.initial === selectedStateId;
      $inspInitBadge.style.display = isInit ? '' : 'none';
      $inspSetInit.style.display   = isInit ? 'none' : '';
      renderActiveTab();
      renderPreview();
    }

    function renderActiveTab() {
      document.querySelectorAll('.insp-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === activeTab));
      document.querySelectorAll('.insp-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === activeTab));
      if      (activeTab === 'embeds')      renderEmbedsPanel();
      else if (activeTab === 'components')  renderComponentsPanel();
      else if (activeTab === 'transitions') renderTransitionsPanel();
      else if (activeTab === 'permissions') renderPermissionsPanel();
    }

    /* ────────────────── Embeds Panel ────────────────── */
    function renderEmbedsPanel() {
      const s = getSelectedState(); if (!s) return;
      const embeds = s.embeds || [];
      let html = embeds.length
        ? embeds.map((emb, i) => {
            const col = emb.color || '#5865f2';
            return '<div class="embed-item" data-idx="' + i + '" style="padding-left:16px;">'
              + '<div class="embed-color-bar" style="background:' + esc(col) + '"></div>'
              + '<div class="embed-item-header">'
              + '<span class="embed-drag"><i data-lucide="grip-vertical" style="width:14px;height:14px;"></i></span>'
              + '<span class="embed-title-lbl"><%= t.embeds.embPrefix %> #' + (i+1) + (emb.title ? ' \u2014 ' + esc(emb.title.slice(0,24)) : '') + '</span>'
              + '<button class="embed-col-btn embed-collapse-btn" data-idx="' + i + '"><i data-lucide="chevron-up" style="width:14px;height:14px;"></i></button>'
              + '<button class="embed-rem-btn embed-remove-btn" data-idx="' + i + '"><i data-lucide="x" style="width:14px;height:14px;"></i></button>'
              + '</div>'
              + '<div class="embed-item-body" id="embedBody' + i + '">' + embedForm(emb, i) + '</div>'
              + '</div>';
          }).join('')
        : '<p style="font-size:.78rem;color:var(--muted);margin-bottom:10px;"><%= t.embeds.jsNoEmbeds %></p>';
      html += '<button class="btn btn-ghost btn-xs" id="btnAddEmbed" style="margin-top:6px;">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> '
        + '<%= t.embeds.jsAddEmbed %></button>';
      $panelEmbeds.innerHTML = html;
      lucide.createIcons();
      bindEmbedEvents();
      document.getElementById('btnAddEmbed').addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.embeds) ss.embeds = [];
        ss.embeds.push({ id: nid('emb'), title: '', description: '', color: '#5865f2', url: '', timestamp: false,
          author: { name: '', iconUrl: '', url: '' }, footer: { text: '', iconUrl: '' },
          thumbnail: '', image: '', fields: [] });
        renderEmbedsPanel(); lucide.createIcons();
      });
    }

    function embedForm(emb, i) {
      return ''
        + '<div class="form-row">'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldTitle %></label>'
        + '<input class="form-input emb-title" data-idx="' + i + '" value="' + esc(emb.title||'') + '" maxlength="256" placeholder="<%= t.embeds.embFldEmbedTitle %>"></div>'
        + '<div class="form-group" style="max-width:70px;"><label class="form-label"><%= t.embeds.embFldColor %></label>'
        + '<div class="form-color-wrap"><input type="color" class="form-color emb-color" data-idx="' + i + '" value="' + (emb.color||'#5865f2') + '"></div></div>'
        + '</div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldDesc %></label>'
        + '<textarea class="form-textarea emb-desc" data-idx="' + i + '" maxlength="4096" placeholder="<%= t.embeds.embFldDescPh %>" style="min-height:70px;">' + esc(emb.description||'') + '</textarea></div>'
        + '<div class="form-row">'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldAuthorName %></label>'
        + '<input class="form-input emb-author-name" data-idx="' + i + '" value="' + esc(emb.author?.name||'') + '" placeholder="<%= t.embeds.embFldAuthorPh %>"></div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldAuthorIcon %></label>'
        + '<div class="url-upload-wrap"><input class="form-input emb-author-icon" data-idx="' + i + '" data-field="author-icon" value="' + esc(emb.author?.iconUrl||'') + '" placeholder="https://...">'
        + '<button type="button" class="upload-btn emb-upload" data-idx="' + i + '" data-field="author-icon" data-target="emb-author-icon"><i data-lucide="upload" style="width:12px;height:12px;"></i></button></div></div>'
        + '</div>'
        + '<div class="form-row">'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldFooterText %></label>'
        + '<input class="form-input emb-footer-text" data-idx="' + i + '" value="' + esc(emb.footer?.text||'') + '" placeholder="<%= t.embeds.embFldFooterPh %>"></div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldFooterIcon %></label>'
        + '<div class="url-upload-wrap"><input class="form-input emb-footer-icon" data-idx="' + i + '" data-field="footer-icon" value="' + esc(emb.footer?.iconUrl||'') + '" placeholder="https://...">'
        + '<button type="button" class="upload-btn emb-upload" data-idx="' + i + '" data-field="footer-icon" data-target="emb-footer-icon"><i data-lucide="upload" style="width:12px;height:12px;"></i></button></div></div>'
        + '</div>'
        + '<div class="form-row">'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldThumbnail %></label>'
        + '<div class="url-upload-wrap"><input class="form-input emb-thumb" data-idx="' + i + '" value="' + esc(emb.thumbnail||'') + '" placeholder="https://...">'
        + '<button type="button" class="upload-btn emb-upload" data-idx="' + i + '" data-field="thumbnail" data-target="emb-thumb"><i data-lucide="upload" style="width:12px;height:12px;"></i></button></div></div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldImage %></label>'
        + '<div class="url-upload-wrap"><input class="form-input emb-image" data-idx="' + i + '" value="' + esc(emb.image||'') + '" placeholder="https://...">'
        + '<button type="button" class="upload-btn emb-upload" data-idx="' + i + '" data-field="image" data-target="emb-image"><i data-lucide="upload" style="width:12px;height:12px;"></i></button></div></div>'
        + '</div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.embFldUrl %></label>'
        + '<input class="form-input emb-url" data-idx="' + i + '" value="' + esc(emb.url||'') + '" placeholder="https://..."></div>'
        + '<label class="form-checkbox"><input type="checkbox" class="emb-timestamp" data-idx="' + i + '"' + (emb.timestamp?' checked':'') + '> <%= t.embeds.embFldTimestamp %></label>'
        + '<div class="form-group" style="margin-top:10px;"><label class="form-label">' + '<%= t.embeds.jsFields %>' + '</label>'
        + '<div class="fields-list" id="fields' + i + '">' + (emb.fields||[]).map((f,fi) => fieldItem(i,fi,f)).join('') + '</div>'
        + '<button class="btn btn-ghost btn-xs btnAddField" data-idx="' + i + '" style="margin-top:6px;">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> ' + '<%= t.embeds.jsAddField %>' + '</button>'
        + '</div>';
    }

    function fieldItem(ei, fi, f) {
      return '<div class="field-item" data-ei="' + ei + '" data-fi="' + fi + '">'
        + '<div><div class="form-group" style="margin-bottom:6px;">'
        + '<input class="form-input field-name" data-ei="' + ei + '" data-fi="' + fi + '" value="' + esc(f.name||'') + '" placeholder="<%= t.embeds.embFldFName %>"></div>'
        + '<div class="form-group" style="margin-bottom:6px;">'
        + '<input class="form-input field-value" data-ei="' + ei + '" data-fi="' + fi + '" value="' + esc(f.value||'') + '" placeholder="<%= t.embeds.embFldFValue %>"></div>'
        + '<label class="form-checkbox" style="font-size:.74rem;">'
        + '<input type="checkbox" class="field-inline" data-ei="' + ei + '" data-fi="' + fi + '"' + (f.inline?' checked':'') + '> <%= t.embeds.embFldInline %></label></div>'
        + '<button class="field-remove" data-ei="' + ei + '" data-fi="' + fi + '">'
        + '<i data-lucide="x" style="width:12px;height:12px;"></i></button>'
        + '</div>';
    }

    function bindEmbedEvents() {
      const s = getSelectedState(); if (!s) return;
      document.querySelectorAll('.emb-title,.emb-desc,.emb-color,.emb-author-name,.emb-author-icon,.emb-footer-text,.emb-footer-icon,.emb-thumb,.emb-image,.emb-url').forEach(el =>
        el.addEventListener('input', () => { syncEmbedFromDOM(+el.dataset.idx); renderPreview(); }));
      document.querySelectorAll('.emb-timestamp').forEach(el =>
        el.addEventListener('change', () => { syncEmbedFromDOM(+el.dataset.idx); renderPreview(); }));
      document.querySelectorAll('.field-name,.field-value').forEach(el =>
        el.addEventListener('input', () => { syncFieldFromDOM(+el.dataset.ei, +el.dataset.fi); renderPreview(); }));
      document.querySelectorAll('.field-inline').forEach(el =>
        el.addEventListener('change', () => { syncFieldFromDOM(+el.dataset.ei, +el.dataset.fi); renderPreview(); }));
      document.querySelectorAll('.embed-remove-btn').forEach(b =>
        b.addEventListener('click', () => {
          const ss = getSelectedState(); if (!ss) return;
          ss.embeds.splice(+b.dataset.idx, 1);
          renderEmbedsPanel(); lucide.createIcons(); renderPreview(); renderCanvas();
        }));
      document.querySelectorAll('.embed-collapse-btn').forEach(b =>
        b.addEventListener('click', () => {
          const body = document.getElementById('embedBody' + b.dataset.idx);
          if (body) body.classList.toggle('collapsed');
        }));
      document.querySelectorAll('.btnAddField').forEach(b =>
        b.addEventListener('click', () => {
          const idx = +b.dataset.idx;
          const ss = getSelectedState(); if (!ss) return;
          if (!ss.embeds[idx].fields) ss.embeds[idx].fields = [];
          if (ss.embeds[idx].fields.length >= 25) return;
          ss.embeds[idx].fields.push({ name: '', value: '', inline: false });
          renderEmbedsPanel(); lucide.createIcons();
        }));
      document.querySelectorAll('.field-remove').forEach(b =>
        b.addEventListener('click', () => {
          const ss = getSelectedState(); if (!ss) return;
          ss.embeds[+b.dataset.ei].fields.splice(+b.dataset.fi, 1);
          renderEmbedsPanel(); lucide.createIcons();
        }));
    }

    function syncEmbedFromDOM(i) {
      const s = getSelectedState(); if (!s) return;
      const emb = s.embeds[i]; if (!emb) return;
      const q = sel => document.querySelector(sel + '[data-idx="' + i + '"]');
      emb.title       = (q('.emb-title')?.value || '').slice(0, 256);
      emb.description = (q('.emb-desc')?.value  || '').slice(0, 4096);
      emb.color       = q('.emb-color')?.value || '';
      emb.author      = { name: q('.emb-author-name')?.value||'', iconUrl: q('.emb-author-icon')?.value||'', url: '' };
      emb.footer      = { text: q('.emb-footer-text')?.value||'', iconUrl: q('.emb-footer-icon')?.value||'' };
      emb.thumbnail   = q('.emb-thumb')?.value  || '';
      emb.image       = q('.emb-image')?.value  || '';
      emb.url         = q('.emb-url')?.value    || '';
      emb.timestamp   = q('.emb-timestamp')?.checked || false;
      markDirty();
    }
    function syncFieldFromDOM(ei, fi) {
      const s = getSelectedState(); if (!s) return;
      const f = s.embeds[ei]?.fields?.[fi]; if (!f) return;
      const q = sel => document.querySelector(sel + '[data-ei="'+ei+'"][data-fi="'+fi+'"]');
      f.name   = q('.field-name')?.value   || '';
      f.value  = q('.field-value')?.value  || '';
      f.inline = q('.field-inline')?.checked || false;
      markDirty();
    }

    /* ────────────────── Components Panel ────────────────── */
    function renderComponentsPanel() {
      const s = getSelectedState(); if (!s) return;
      const comps = s.components || [];
      let html = comps.map((row, ri) => {
        if (row.type === 'buttons') return buttonRowHTML(row, ri);
        if (row.type === 'select')  return selectRowHTML(row, ri);
        return '';
      }).join('');
      html += '<div style="display:flex;gap:8px;margin-top:8px;">'
        + '<button class="btn btn-ghost btn-xs" id="btnAddBtnRow">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> '
        + '<%= t.embeds.jsAddButtons %></button>'
        + '<button class="btn btn-ghost btn-xs" id="btnAddSelRow">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> '
        + '<%= t.embeds.jsAddSelect %></button>'
        + '</div>';
      $panelComponents.innerHTML = html;
      lucide.createIcons();
      bindCompEvents();
      document.getElementById('btnAddBtnRow').addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.components) ss.components = [];
        if (ss.components.length >= 5) return toast('Max 5 rows', 'error');
        const cid = nid('btn');
        ss.components.push({ id: nid('row'), type: 'buttons', buttons: [{ customId: cid, label: '<%= t.embeds.jsButton %>', style: 'Primary', emoji: '', url: '', disabled: false }], select: null });
        renderComponentsPanel(); lucide.createIcons();
      });
      document.getElementById('btnAddSelRow').addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        if (!ss.components) ss.components = [];
        if (ss.components.length >= 5) return toast('Max 5 rows', 'error');
        const cid = nid('sel'), ocid = nid('opt');
        ss.components.push({ id: nid('row'), type: 'select', buttons: [], select: { customId: cid, placeholder: 'Select an option\u2026', minValues: 1, maxValues: 1, disabled: false, options: [{ customId: ocid, label: '<%= t.embeds.jsOption %>', value: ocid, description: '', emoji: '', default: false }] } });
        renderComponentsPanel(); lucide.createIcons();
      });
    }

    function buttonRowHTML(row, ri) {
      return '<div class="comp-row" data-ri="' + ri + '">'
        + '<div class="comp-row-header"><span class="comp-type-badge btn-type"><i data-lucide="layout-grid" style="width:10px;height:10px;"></i> <%= t.embeds.compBadgeBtns %></span>'
        + '<span class="comp-row-lbl"><%= t.embeds.compRowLbl %> #' + (ri + 1) + '</span>'
        + '<button class="comp-rem-btn comp-remove-row" data-ri="' + ri + '"><i data-lucide="x" style="width:14px;height:14px;"></i></button></div>'
        + (row.buttons || []).map((b, bi) => ''
          + '<div class="btn-item" data-ri="' + ri + '" data-bi="' + bi + '">'
          + '<div class="form-group" style="margin-bottom:0;flex:1;min-width:0;">'
          + '<input class="form-input btn-label" data-ri="' + ri + '" data-bi="' + bi + '" value="' + esc(b.label||'') + '" placeholder="<%= t.embeds.compLabelPh %>"></div>'
          + '<select class="form-select btn-style" data-ri="' + ri + '" data-bi="' + bi + '" style="width:100px;flex-shrink:0;">'
          + ['Primary','Secondary','Success','Danger','Link'].map(ss => '<option value="' + ss + '"' + (b.style===ss?' selected':'') + '>' + ss + '</option>').join('')
          + '</select>'
          + '<button type="button" class="emoji-trigger btn-emoji-pick" data-ri="' + ri + '" data-bi="' + bi + '" data-val="' + esc(b.emoji||'') + '" title="Emoji">'
          + renderEmojiBtn(b.emoji) + '</button>'
          + '<input type="hidden" class="btn-emoji" data-ri="' + ri + '" data-bi="' + bi + '" value="' + esc(b.emoji||'') + '">'
          + (b.style === 'Link' ? '<input class="form-input btn-url" data-ri="'+ri+'" data-bi="'+bi+'" value="'+esc(b.url||'')+'" placeholder="URL" style="max-width:120px;">' : '')
          + '<button class="btn-remove-btn" data-ri="' + ri + '" data-bi="' + bi + '">'
          + '<i data-lucide="x" style="width:12px;height:12px;"></i></button>'
          + '</div>').join('')
        + '<button class="btn btn-ghost btn-xs btnAddBtn" data-ri="' + ri + '" style="margin-top:6px;">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> ' + '<%= t.embeds.jsButton %>' + '</button>'
        + '</div>';
    }

    function selectRowHTML(row, ri) {
      const sel = row.select || {};
      return '<div class="comp-row" data-ri="' + ri + '">'
        + '<div class="comp-row-header"><span class="comp-type-badge sel-type"><i data-lucide="chevrons-up-down" style="width:10px;height:10px;"></i> <%= t.embeds.compBadgeSel %></span>'
        + '<span class="comp-row-lbl"><%= t.embeds.compRowLbl %> #' + (ri + 1) + '</span>'
        + '<button class="comp-rem-btn comp-remove-row" data-ri="' + ri + '"><i data-lucide="x" style="width:14px;height:14px;"></i></button></div>'
        + '<div class="form-group"><label class="form-label"><%= t.embeds.compSelectLabel %></label>'
        + '<input class="form-input sel-placeholder" data-ri="' + ri + '" value="' + esc(sel.placeholder||'') + '" placeholder="Select an option\u2026"></div>'
        + (sel.options || []).map((o, oi) => ''
          + '<div class="select-opt-item" data-ri="' + ri + '" data-oi="' + oi + '">'
          + '<div class="form-group" style="margin-bottom:0;flex:1;min-width:0;">'
          + '<input class="form-input opt-label" data-ri="' + ri + '" data-oi="' + oi + '" value="' + esc(o.label||'') + '" placeholder="<%= t.embeds.compLabelPh %>"></div>'
          + '<div class="form-group" style="margin-bottom:0;flex:1;min-width:0;">'
          + '<input class="form-input opt-desc" data-ri="' + ri + '" data-oi="' + oi + '" value="' + esc(o.description||'') + '" placeholder="<%= t.embeds.compOptDescPh %>"></div>'
          + '<button type="button" class="emoji-trigger opt-emoji-pick" data-ri="' + ri + '" data-oi="' + oi + '" data-val="' + esc(o.emoji||'') + '" title="Emoji">'
          + renderEmojiBtn(o.emoji) + '</button>'
          + '<input type="hidden" class="opt-emoji" data-ri="' + ri + '" data-oi="' + oi + '" value="' + esc(o.emoji||'') + '">'
          + '<button class="opt-remove" data-ri="'+ri+'" data-oi="'+oi+'"><i data-lucide="x" style="width:12px;height:12px;"></i></button>'
          + '</div>').join('')
        + '<button class="btn btn-ghost btn-xs btnAddOpt" data-ri="' + ri + '" style="margin-top:6px;">'
        + '<i data-lucide="plus" style="width:12px;height:12px;"></i> ' + '<%= t.embeds.jsOption %>' + '</button>'
        + '</div>';
    }

    function bindCompEvents() {
      document.querySelectorAll('.comp-remove-row').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        ss.components.splice(+b.dataset.ri, 1);
        renderComponentsPanel(); lucide.createIcons(); renderPreview();
      }));
      document.querySelectorAll('.btn-label,.btn-url').forEach(el =>
        el.addEventListener('input', () => { syncBtnFromDOM(+el.dataset.ri, +el.dataset.bi); renderPreview(); }));
      document.querySelectorAll('.btn-style').forEach(el =>
        el.addEventListener('change', () => { syncBtnFromDOM(+el.dataset.ri, +el.dataset.bi); renderComponentsPanel(); lucide.createIcons(); }));
      document.querySelectorAll('.btn-remove-btn').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        ss.components[+b.dataset.ri].buttons.splice(+b.dataset.bi, 1);
        renderComponentsPanel(); lucide.createIcons();
      }));
      document.querySelectorAll('.btnAddBtn').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        const ri = +b.dataset.ri;
        if ((ss.components[ri].buttons || []).length >= 5) return;
        const cid = nid('btn');
        ss.components[ri].buttons.push({ customId: cid, label: '<%= t.embeds.jsButton %>', style: 'Primary', emoji: '', url: '', disabled: false });
        renderComponentsPanel(); lucide.createIcons();
      }));
      document.querySelectorAll('.sel-placeholder').forEach(el => el.addEventListener('input', () => {
        const ss = getSelectedState(); if (!ss) return;
        if (ss.components[+el.dataset.ri]?.select) ss.components[+el.dataset.ri].select.placeholder = el.value;
        renderPreview();
      }));
      document.querySelectorAll('.opt-label,.opt-desc').forEach(el =>
        el.addEventListener('input', () => { syncOptFromDOM(+el.dataset.ri, +el.dataset.oi); renderPreview(); }));
      document.querySelectorAll('.opt-remove').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        ss.components[+b.dataset.ri].select.options.splice(+b.dataset.oi, 1);
        renderComponentsPanel(); lucide.createIcons();
      }));
      document.querySelectorAll('.btnAddOpt').forEach(b => b.addEventListener('click', () => {
        const ss = getSelectedState(); if (!ss) return;
        const ri = +b.dataset.ri;
        const sel = ss.components[ri].select;
        if ((sel.options || []).length >= 25) return;
        const cid = nid('opt');
        sel.options.push({ customId: cid, label: '<%= t.embeds.jsOption %>', value: cid, description: '', emoji: '', default: false });
        renderComponentsPanel(); lucide.createIcons();
      }));
      // Emoji – buttons
      document.querySelectorAll('.btn-emoji-pick').forEach(el => el.addEventListener('click', e => {
        e.stopPropagation();
        openEmbEmojiPicker(el, val => {
          el.dataset.val = val;
          el.innerHTML   = renderEmojiBtn(val);
          const hid = document.querySelector('.btn-emoji[data-ri="'+el.dataset.ri+'"][data-bi="'+el.dataset.bi+'"]');
          if (hid) { hid.value = val; syncBtnFromDOM(+el.dataset.ri, +el.dataset.bi); renderPreview(); }
        });
      }));
      // Emoji – options
      document.querySelectorAll('.opt-emoji-pick').forEach(el => el.addEventListener('click', e => {
        e.stopPropagation();
        openEmbEmojiPicker(el, val => {
          el.dataset.val = val;
          el.innerHTML   = renderEmojiBtn(val);
          const hid = document.querySelector('.opt-emoji[data-ri="'+el.dataset.ri+'"][data-oi="'+el.dataset.oi+'"]');
          if (hid) { hid.value = val; syncOptFromDOM(+el.dataset.ri, +el.dataset.oi); renderPreview(); }
        });
      }));
    }

    function syncBtnFromDOM(ri, bi) {
      const s = getSelectedState(); if (!s) return;
      const btn = s.components[ri]?.buttons?.[bi]; if (!btn) return;
      const q = sel => document.querySelector(sel + '[data-ri="'+ri+'"][data-bi="'+bi+'"]');
      btn.label = q('.btn-label')?.value || 'Button';
      btn.style = q('.btn-style')?.value || 'Primary';
      btn.emoji = q('.btn-emoji')?.value || '';
